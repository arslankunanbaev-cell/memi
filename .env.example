VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key
VITE_LASTFM_API_KEY=your-lastfm-api-key
# Spotify — optional, enables highest-quality album art
# Get from https://developer.spotify.com/dashboard → create app → Client ID + Secret
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Telegram bot username (without @) — used for invite deep links
VITE_BOT_USERNAME=your_bot_username
